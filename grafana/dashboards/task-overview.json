{
  "dashboard": {
    "title": "Nash Framework - Task Overview",
    "tags": ["nash", "tasks"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5s",
    "time": {
      "from": "now-6h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "gauge",
        "title": "Task Completion Rate (24h)",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(nash_tasks_total{status=\"completed\"}[24h]) / rate(nash_tasks_total[24h]) * 100",
            "legendFormat": "Completion %",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "orientation": "auto",
          "textMode": "value_and_name",
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "red" },
                { "value": 70, "color": "yellow" },
                { "value": 90, "color": "green" }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "type": "piechart",
        "title": "Tasks by Status",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 6,
          "h": 8
        },
        "targets": [
          {
            "expr": "nash_tasks_total{status=\"pending\"}",
            "legendFormat": "Pending",
            "refId": "A"
          },
          {
            "expr": "nash_tasks_total{status=\"running\"}",
            "legendFormat": "Running",
            "refId": "B"
          },
          {
            "expr": "nash_tasks_total{status=\"completed\"}",
            "legendFormat": "Completed",
            "refId": "C"
          },
          {
            "expr": "nash_tasks_total{status=\"failed\"}",
            "legendFormat": "Failed",
            "refId": "D"
          }
        ],
        "options": {
          "reduceOptions": {
            "calcs": ["lastNotNull"]
          },
          "pieType": "pie",
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        }
      },
      {
        "id": 3,
        "type": "graph",
        "title": "Task Duration Histogram",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(nash_task_duration_seconds_bucket[5m]))",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(nash_task_duration_seconds_bucket[5m]))",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(nash_task_duration_seconds_bucket[5m]))",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "yaxes": [
          {
            "label": "Duration (seconds)",
            "format": "s"
          }
        ]
      },
      {
        "id": 4,
        "type": "timeseries",
        "title": "Tasks Over Time",
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "rate(nash_tasks_total{status=\"pending\"}[5m])",
            "legendFormat": "Pending",
            "refId": "A"
          },
          {
            "expr": "rate(nash_tasks_total{status=\"running\"}[5m])",
            "legendFormat": "Running",
            "refId": "B"
          },
          {
            "expr": "rate(nash_tasks_total{status=\"completed\"}[5m])",
            "legendFormat": "Completed",
            "refId": "C"
          },
          {
            "expr": "rate(nash_tasks_total{status=\"failed\"}[5m])",
            "legendFormat": "Failed",
            "refId": "D"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "list",
            "placement": "bottom"
          }
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 30,
              "stacking": {
                "mode": "normal"
              }
            },
            "unit": "ops"
          }
        }
      }
    ]
  }
}
